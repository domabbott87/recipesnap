# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com
# Used for: recipe extraction from photos, URLs and Instagram captions
ANTHROPIC_API_KEY=sk-ant-...

# Session encryption secret — use a long random string in production
# Generate one with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ── Optional ──────────────────────────────────────────────────────────────────

# Port to listen on (defaults to 3000)
PORT=3000

# Directory where SQLite database file is stored
# On Railway: set to /app/data  (matches the volume mount)
# On Render:  set to /var/data  (matches render.yaml)
# Locally:    leave unset, defaults to ./data
DATA_DIR=

# Node environment
NODE_ENV=production
